@{
    ViewData["Title"] = "Смена пароля";
}

<div class="container py-4">
    <div class="row">
        <!-- Боковое меню пользователя -->
        <div class="col-md-3">
            <div class="list-group shadow-sm">
                <a href="/Account/Profile" class="list-group-item list-group-item-action">
                    <i class="fas fa-user me-2"></i> Личный кабинет
                </a>
                <a href="/Account/MyBookings" class="list-group-item list-group-item-action">
                    <i class="fas fa-history me-2"></i> Мои поездки
                </a>
                <a href="/Account/ChangePassword" class="list-group-item list-group-item-action active">
                    <i class="fas fa-key me-2"></i> Сменить пароль
                </a>
                <a href="/Account/AddFunds" class="list-group-item list-group-item-action">
                    <i class="fas fa-plus-circle me-2"></i> Пополнить баланс
                </a>
                <div class="dropdown-divider"></div>
                <a href="/Account/Logout" class="list-group-item list-group-item-action text-danger">
                    <i class="fas fa-sign-out-alt me-2"></i> Выйти
                </a>
            </div>
        </div>

        <!-- Основной контент -->
        <div class="col-md-9">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Смена пароля</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }
                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success">@ViewBag.Success</div>
                    }

                    <form method="post" action="/Account/ChangePassword">
                        <div class="mb-3">
                            <label class="form-label">Текущий пароль</label>
                            <input type="password" name="currentPassword" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Новый пароль</label>
                            <input type="password" name="newPassword" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Подтверждение нового пароля</label>
                            <input type="password" name="confirmPassword" class="form-control" required>
                        </div>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-key me-2"></i>Сменить пароль
                        </button>
                        <a href="/Account/Profile" class="btn btn-secondary">
                            <i class="fas fa-times me-2"></i>Отмена
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>


