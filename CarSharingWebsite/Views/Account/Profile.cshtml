@model CarSharingWebsite.Models.User
@{
    ViewData["Title"] = "Личный кабинет";
}

<div class="container py-4">
    <div class="row">
        <!-- Боковое меню пользователя -->
        <div class="col-md-3">
            <div class="card shadow-sm mb-4 border-0 rounded-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                <div class="card-body text-center py-4">
                    <div class="bg-white text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow" style="width: 100px; height: 100px;">
                        <i class="fas fa-user fa-3x"></i>
                    </div>
                    <h5 class="fw-bold mb-1">@Model.first_name</h5>
                    <p class="text-white-50 mb-3">@Model.Login</p>
                    @if (Model.Role == "Admin")
                    {
                        <span class="badge bg-danger px-3 py-2 rounded-pill shadow-sm">Администратор</span>
                    }
                    else
                    {
                        <span class="badge bg-success px-3 py-2 rounded-pill shadow-sm" style="background: #00D2D3 !important; color: #1a1a2e !important;">Клиент</span>
                    }
                </div>
            </div>

            <!-- Рейтинг вождения -->
            @if (Model.IsVerified && ViewBag.HasCompletedBookings == true)
            {
            <div class="card shadow-sm mb-4 border-0 rounded-4 overflow-hidden" style="background: #1a1a2e; color: white;">
                <div class="card-body p-4 text-center">
                    <h6 class="mb-3 fw-bold text-uppercase" style="letter-spacing: 1px; font-size: 0.8rem; color: #a1a1b5;">
                        <i class="fas fa-tachometer-alt me-2 text-warning"></i>Рейтинг вождения
                    </h6>
                    <div class="position-relative d-inline-block mb-3">
                        <svg viewBox="0 0 36 36" style="width: 100px; height: 100px;">
                            <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#2d2d44" stroke-width="3"></path>
                            <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#00D2D3" stroke-width="2.5" stroke-dasharray="92, 100" stroke-linecap="round"></path>
                        </svg>
                        <div class="position-absolute top-50 start-50 translate-middle w-100">
                            <div class="fs-3 fw-bold" style="color: #00D2D3;">92</div>
                        </div>
                    </div>
                    <h6 class="fw-bold mb-1">Аккуратный водитель</h6>
                    <p class="small mb-0" style="color: #a1a1b5;">Скидка 5% на все поездки активна.</p>
                </div>
            </div>
            }

            <div class="list-group shadow-sm border-0 rounded-4 overflow-hidden mb-4">
                <a href="/Account/Profile" class="list-group-item list-group-item-action active border-0" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <i class="fas fa-user me-3 w-20px text-center"></i> Личный кабинет
                </a>
                <a href="/Account/MyBookings" class="list-group-item list-group-item-action border-0 py-3">
                    <i class="fas fa-history me-3 w-20px text-center text-primary"></i> Мои поездки
                </a>
                <a href="/Account/ChangePassword" class="list-group-item list-group-item-action border-0 py-3">
                    <i class="fas fa-key me-3 w-20px text-center text-primary"></i> Сменить пароль
                </a>
                <a href="/Account/AddFunds" class="list-group-item list-group-item-action border-0 py-3">
                    <i class="fas fa-plus-circle me-3 w-20px text-center text-success"></i> Пополнить баланс
                </a>
                <div class="dropdown-divider m-0"></div>
                <a href="/Account/Logout" class="list-group-item list-group-item-action border-0 py-3 text-danger fw-bold">
                    <i class="fas fa-sign-out-alt me-3 w-20px text-center"></i> Выйти
                </a>
            </div>
        </div>

        <!-- Основной контент -->
        <div class="col-md-9">
            @if(TempData["Success"] != null)
            {
                <div class="alert alert-success shadow-sm rounded-4 border-0 mb-4">
                    <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                </div>
            }

            @if (!Model.IsVerified && Model.Role != "Admin")
            {
                <div class="card shadow-sm border-0 rounded-4 mb-4 border-start border-4 border-warning" style="background: #fff8e1;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold text-warning mb-3"><i class="fas fa-exclamation-triangle me-2"></i>Требуется верификация документов</h5>
                        <p class="text-muted mb-4">Для того чтобы начать арендовать автомобили, загрузите четкие фотографии вашего паспорта и водительского удостоверения. Администратор проверит их в кратчайшие сроки.</p>
                        
                        <form action="/Account/UploadDocuments" method="post" enctype="multipart/form-data">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-secondary text-uppercase" style="font-size: 0.8rem; letter-spacing: 0.5px;">Фото паспорта</label>
                                    <input type="file" name="passport" class="form-control form-control-lg bg-light border-0" accept="image/*" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-secondary text-uppercase" style="font-size: 0.8rem; letter-spacing: 0.5px;">Фото ВУ</label>
                                    <input type="file" name="license" class="form-control form-control-lg bg-light border-0" accept="image/*" required>
                                </div>

                                <div class="col-md-12 mt-4">
                                    <button type="submit" class="btn btn-warning fw-bold px-4 py-2 rounded-pill shadow-sm">
                                        <i class="fas fa-paper-plane me-2"></i>Отправить на проверку
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            }

            <!-- Баланс -->
            <div class="card shadow-sm mb-4 border-0 rounded-4" style="background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);">
                <div class="card-body p-4">
                    <div class="row align-items-center">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <h5 class="mb-1 text-muted fw-bold">Ваш баланс</h5>
                            <p class="mb-0 text-secondary small">Для комфортных поездок</p>
                        </div>
                        <div class="col-md-3 mb-3 mb-md-0">
                            <h2 class="text-primary mb-0 fw-bold" style="font-family: 'Orbitron', sans-serif;">@ViewBag.Balance.ToString("F2") <span class="fs-6 text-muted">BYN</span></h2>
                        </div>
                        <div class="col-md-3 text-md-end">
                            <a href="/Account/AddFunds" class="btn btn-primary rounded-pill px-4 shadow-sm">
                                <i class="fas fa-plus-circle me-2"></i>Пополнить
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Информация о пользователе -->
            <div class="card shadow-sm border-0 rounded-4 mb-5">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-id-card text-primary me-2"></i>Личные данные</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-4 h-100 border-start border-4 border-primary">
                                <label class="fw-bold text-muted small mb-1"><i class="fas fa-user-circle me-2"></i>ФИО</label>
                                <p class="mb-0 fw-semibold fs-5">@(string.IsNullOrEmpty(Model.first_name) ? "Не указано" : Model.first_name)</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-4 h-100 border-start border-4 border-info">
                                <label class="fw-bold text-muted small mb-1"><i class="fas fa-at me-2"></i>Логин</label>
                                <p class="mb-0 fw-semibold fs-5">@Model.Login</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-4 h-100">
                                <label class="fw-bold text-muted small mb-1"><i class="fas fa-phone-alt me-2 text-success"></i>Телефон</label>
                                <p class="mb-0 fw-semibold">@(string.IsNullOrEmpty(Model.phone) ? "Не указано" : Model.phone)</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-4 h-100">
                                <label class="fw-bold text-muted small mb-1"><i class="fas fa-envelope me-2 text-warning"></i>Email</label>
                                <p class="mb-0 fw-semibold">@(string.IsNullOrEmpty(Model.Email) ? "Не указано" : Model.Email)</p>
                            </div>
                        </div>

                        <div class="col-md-12">
                            <div class="p-3 bg-light rounded-4 h-100">
                                <label class="fw-bold text-muted small mb-1"><i class="fas fa-id-badge me-2 text-primary"></i>Водительское удостоверение</label>
                                <p class="mb-0 fw-semibold text-dark">@(ViewBag.ClientInfo?.license_number ?? "Не указано")</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-4 h-100">
                                <label class="fw-bold text-muted small mb-1"><i class="fas fa-calendar-check me-2 text-secondary"></i>Дата регистрации</label>
                                <p class="mb-0 fw-semibold">@Model.registration_date?.ToString("dd.MM.yyyy")</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded-4 h-100">
                                <label class="fw-bold text-muted small mb-1"><i class="fas fa-shield-alt me-2 text-danger"></i>Статус профиля</label>
                                <p class="mb-0">
                                    @if (Model.Role == "Admin")
                                    {
                                        <span class="badge bg-danger rounded-pill px-3 shadow-sm">Администратор</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success rounded-pill px-3 shadow-sm" style="background: #00D2D3 !important; color: #1a1a2e !important;">Активный клиент</span>
                                    }
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



