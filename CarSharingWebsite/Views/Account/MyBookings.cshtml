@model List<CarSharingWebsite.Models.Booking>
@{
    ViewData["Title"] = "Мои поездки";
}

<div class="my-trips-page py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <h2 class="display-5 fw-bold text-gradient">Мои поездки</h2>
            <a href="/Home/Cars" class="btn btn-premium">
                <i class="fas fa-plus me-2"></i>Новая поездка
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-glass alert-success border-0 fade show animate-fade-in" role="alert">
                <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-glass alert-danger border-0 fade show animate-fade-in" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
            </div>
        }

        @if (Model != null && Model.Any())
        {
            <div class="glass-card overflow-hidden animate-slide-up">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">Автомобиль</th>
                                <th>Дата</th>
                                <th>Время</th>
                                <th>Стоимость</th>
                                <th>Статус</th>
                                <th>Оплата</th>
                                <th class="text-center pe-4">Удалить</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var booking in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="car-icon me-3">
                                                <i class="fas fa-car"></i>
                                            </div>
                                            <div>
                                                <div class="fw-bold fs-5">@(booking.Car?.Brand) @(booking.Car?.Model)</div>
                                                <small class="text-muted">@(booking.Car?.LicensePlate ?? "Без номера")</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="fw-medium">@booking.start_datetime?.ToString("dd.MM.yyyy")</div>
                                    </td>
                                    <td>
                                        <div class="text-nowrap">
                                            <i class="far fa-clock text-primary me-1"></i>
                                            @booking.start_datetime?.ToString("HH:mm") - @booking.end_datetime?.ToString("HH:mm")
                                        </div>
                                    </td>
                                    @{
                                        decimal cost = 0;
                                        if (booking.start_datetime.HasValue && booking.end_datetime.HasValue && booking.Car?.Tariffs?.FirstOrDefault() != null)
                                        {
                                            var minutes = (decimal)(booking.end_datetime.Value - booking.start_datetime.Value).TotalMinutes;
                                            var price = booking.Car.Tariffs.First().price_per_minute ?? 0m;
                                            cost = Math.Max(0m, minutes) * price;
                                        }
                                    }
                                    <td>
                                        <div class="cost-badge">@cost.ToString("F2") BYN</div>
                                    </td>
                                    <td>
                                        @if (booking.Status == "Активна")
                                        {
                                            <span class="badge badge-glow bg-success">Активна</span>
                                        }
                                        else if (booking.Status == "Завершена")
                                        {
                                            <span class="badge badge-glow bg-secondary">Завершена</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-glow bg-danger">@booking.Status</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-soft-success text-success border border-success border-opacity-25">
                                            <i class="fas fa-check me-1"></i>Оплачено
                                        </span>
                                    </td>
                                    <td class="text-center pe-4">
                                        <a href="/Account/DeleteBooking/@booking.ID_Booking" 
                                           class="btn btn-icon btn-soft-danger" 
                                           onclick="return confirm('Удалить бронирование @(booking.Car?.Brand) @(booking.Car?.Model)?')">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="glass-card text-center py-5 animate-fade-in">
                <div class="empty-state">
                    <div class="empty-icon mb-4">
                        <i class="fas fa-road fa-3x"></i>
                    </div>
                    <h3 class="fw-bold mb-3">У вас пока нет поездок</h3>
                    <p class="text-muted mb-4">Вы еще не забронировали ни одного автомобиля. Начните свое приключение прямо сейчас!</p>
                    <a href="/Home/Cars" class="btn btn-premium btn-lg">Найти автомобиль</a>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .my-trips-page {
        background: #f8fafc;
        min-height: 80vh;
    }

    .text-gradient {
        background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .table thead th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.05em;
        color: #64748b;
        padding: 20px 15px;
        border-bottom: 2px solid #f1f5f9;
    }

    .table tbody td {
        padding: 20px 15px;
        border-bottom: 1px solid #f1f5f9;
        color: #1e293b;
    }

    .car-icon {
        width: 45px;
        height: 45px;
        background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #475569;
        font-size: 1.2rem;
    }

    .cost-badge {
        font-weight: 700;
        color: #059669;
        background: #ecfdf5;
        padding: 6px 12px;
        border-radius: 10px;
        display: inline-block;
    }

    .badge-glow {
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        padding: 8px 12px;
        border-radius: 8px;
    }

    .bg-soft-success { background: rgba(16, 185, 129, 0.1); }
    .btn-soft-danger {
        color: #ef4444;
        background: rgba(239, 68, 68, 0.1);
        border: none;
    }
    .btn-soft-danger:hover {
        background: #ef4444;
        color: white;
    }

    .btn-icon {
        width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        transition: all 0.3s;
    }

    .btn-premium {
        background: linear-gradient(135deg, #334155 0%, #1e293b 100%);
        color: white;
        padding: 12px 24px;
        border-radius: 12px;
        font-weight: 600;
        border: none;
        transition: all 0.3s;
    }

    .btn-premium:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(30, 41, 59, 0.3);
        color: white;
    }

    .alert-glass {
        backdrop-filter: blur(5px);
        border-radius: 12px;
    }

    .animate-slide-up {
        animation: slideUp 0.6s ease-out;
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .animate-fade-in {
        animation: fadeIn 0.8s ease-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
</style>


