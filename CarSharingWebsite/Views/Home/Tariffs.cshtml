<script>
    function switchTariff(type) {
        // Обновляем активную кнопку
        document.querySelectorAll('.toggle-btn').forEach(btn => {
            btn.classList.remove('active');
        });
        event.target.classList.add('active');

        // Показываем соответствующий блок тарифов
        document.querySelectorAll('.tariff-grid').forEach(grid => {
            grid.classList.remove('active');
        });
        document.getElementById(`tariff-${type}`).classList.add('active');
    }

    function calculatePrice() {
        const startTime = new Date(document.getElementById('startTime').value);
        const endTime = new Date(document.getElementById('endTime').value);
        const rate = parseFloat(document.getElementById('tariffType').value);

        if (startTime && endTime && endTime > startTime) {
            const minutes = (endTime - startTime) / (1000 * 60);
            const price = minutes * rate;
            document.getElementById('calcResult').textContent = `${Math.round(price)} BYN`;
        } else {
            document.getElementById('calcResult').textContent = 'Укажите корректное время';
        }
    }
</script>


