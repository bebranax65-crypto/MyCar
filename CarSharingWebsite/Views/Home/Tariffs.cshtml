                <button class="toggle-btn" onclick="switchTariff('days')">Посуточно</button>
                <button class="toggle-btn" onclick="switchTariff('subscription')">Подписка</button>
            </div>
            <div class="discount-badge">
                <i class="fas fa-gift"></i>
                Скидка 20% на первые 3 поездки
            </div>
        </div>

        <!-- Тарифы Поминутно -->
        <div id="tariff-minutes" class="tariff-grid active">
            <div class="tariff-card featured">
                <div class="tariff-badge">Популярный</div>
                <div class="tariff-icon">
                    <i class="fas fa-clock"></i>
                </div>
                <h3 class="tariff-name">Эконом</h3>
                <div class="tariff-price">
                    <span class="price-value">0,24</span>
                    <span class="price-currency">BYN</span>
                    <span class="price-period">/мин</span>
                </div>
                <ul class="tariff-features">
                    <li><i class="fas fa-check"></i> Бензин включен</li>
                    <li><i class="fas fa-check"></i> Страховка включена</li>
                    <li><i class="fas fa-check"></i> Бесплатная парковка</li>
                    <li><i class="fas fa-check"></i> Hyundai, Kia, Renault</li>
                    <li class="disabled"><i class="fas fa-times"></i> Бизнес-класс</li>
                    <li class="disabled"><i class="fas fa-times"></i> Приоритетная поддержка</li>
                </ul>
                @if (isLoggedIn)
                {
                    <button class="btn-tariff" onclick="location.href='/Home/Cars'">
                        Выбрать тариф
                        <i class="fas fa-arrow-right"></i>
                    </button>
