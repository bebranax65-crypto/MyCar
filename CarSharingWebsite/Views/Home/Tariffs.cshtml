@{
    ViewData["Title"] = "Тарифы";
    var isLoggedIn = Context.Session.GetInt32("UserId") != null;
    var userRole = Context.Session.GetString("UserRole");
}

<!-- Hero секция -->
<section class="tariffs-hero">
    <div class="container">
        <div class="text-center">
            <h1 class="tariffs-hero-title">Выберите свой тариф</h1>
            <p class="tariffs-hero-subtitle">Прозрачные цены без скрытых платежей. Платите только за то, чем пользуетесь.</p>
        </div>
    </div>
</section>

<!-- Переключатель тарифов -->
