        <!-- Калькулятор стоимости -->
        <section class="calculator-section">
            <div class="container">
                <div class="calculator-card">
                    <div class="row align-items-center">
                        <div class="col-lg-6">
                            <h2 class="calculator-title">Рассчитайте стоимость поездки</h2>
                            <p class="calculator-subtitle">Используйте наш калькулятор, чтобы узнать примерную стоимость аренды</p>
                        </div>
                        <div class="col-lg-6">
                            <div class="calculator-form">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Время начала</label>
                                        <input type="datetime-local" class="form-control" id="startTime">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Время окончания</label>
                                        <input type="datetime-local" class="form-control" id="endTime">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Тариф</label>
                                        <select class="form-select" id="tariffType">
                                            <option value="0.24">Эконом (0,24 BYN/мин)</option>
                                            <option value="0.29">Комфорт (0,29 BYN/мин)</option>
                                            <option value="0.39">Премиум (0,39 BYN/мин)</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Примерная стоимость</label>
                                        <div class="calc-result" id="calcResult">0 BYN</div>
                                    </div>
                                    <div class="col-12">
                                        <button class="btn-calculate" onclick="calculatePrice()">
                                            <i class="fas fa-calculator me-2"></i>Рассчитать
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

