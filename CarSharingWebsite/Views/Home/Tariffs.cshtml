        <!-- FAQ -->
        <section class="faq-section">
            <div class="container">
                <h2 class="text-center mb-5">Часто задаваемые вопросы</h2>
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <div class="accordion" id="faqAccordion">
                            <div class="accordion-item">
                                <h3 class="accordion-header">
                                    <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                        Что включено в стоимость аренды?
                                    </button>
                                </h3>
                                <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                                    <div class="accordion-body">
                                        В стоимость аренды включены: бензин, страховка ОСАГО, техническое обслуживание автомобиля, круглосуточная поддержка. Дополнительно оплачиваются только платные парковки и штрафы.
                                    </div>
                                </div>
                            </div>
                            <div class="accordion-item">
                                <h3 class="accordion-header">
                                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                        Как происходит оплата?
                                    </button>
                                </h3>
                                <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                                    <div class="accordion-body">
                                        Оплата происходит автоматически после каждой поездки. Средства списываются с привязанной банковской карты. Вы можете просматривать историю платежей в личном кабинете.
                                    </div>
                                </div>
                            </div>
                            <div class="accordion-item">
                                <h3 class="accordion-header">
                                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                                        Где можно оставить автомобиль?
                                    </button>
                                </h3>
                                <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                                    <div class="accordion-body">
                                        Вы можете завершить аренду в любой парковочной зоне на карте. Не забывайте проверять, что вы находитесь в разрешенной зоне завершения аренды.
                                    </div>
                                </div>
                            </div>
                            <div class="accordion-item">
                                <h3 class="accordion-header">
                                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                                        Что делать при ДТП?
                                    </button>
                                </h3>
