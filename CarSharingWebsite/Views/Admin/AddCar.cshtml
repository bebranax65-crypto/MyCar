@model CarSharingWebsite.Models.Car
@{
    ViewData["Title"] = "Добавление автомобиля";
}

<div class="container-fluid py-4">
    <div class="row">
        <!-- Боковое меню -->
        <div class="col-md-2">
            <div class="list-group">
                <a href="/Admin/Dashboard" class="list-group-item list-group-item-action">
                    <i class="fas fa-tachometer-alt me-2"></i> Дашборд
                </a>
                <a href="/Admin/Users" class="list-group-item list-group-item-action">
                    <i class="fas fa-users me-2"></i> Пользователи
                </a>
                <a href="/Admin/ManageCars" class="list-group-item list-group-item-action active">
                    <i class="fas fa-car me-2"></i> Автомобили
                </a>
                <a href="/Admin/Bookings" class="list-group-item list-group-item-action">
                    <i class="fas fa-calendar-check me-2"></i> Бронирования
                </a>
                <a href="/Admin/Statistics" class="list-group-item list-group-item-action">
                    <i class="fas fa-chart-bar me-2"></i> Статистика
                </a>
                <div class="dropdown-divider"></div>
                <a href="/Account/Logout" class="list-group-item list-group-item-action text-danger">
                    <i class="fas fa-sign-out-alt me-2"></i> Выход
                </a>
            </div>
        </div>

        <!-- Основной контент -->
        <div class="col-md-10">
            <div class="card">
                <div class="card-header bg-white">
                    <h4 class="mb-0">Добавить новый автомобиль</h4>
                </div>
                <div class="card-body">
                    <form method="post" action="/Admin/AddCar" enctype="multipart/form-data">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Марка</label>
                                <input type="text" name="Brand" class="form-control" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Модель</label>
                                <input type="text" name="Model" class="form-control" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Госномер</label>
                                <input type="text" name="LicensePlate" class="form-control" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Коробка передач</label>
                                <select name="condition" class="form-select">
                                    <option value="Автомат">Автомат</option>
                                    <option value="Механика">Механика</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Тип топлива</label>
                                <input type="text" name="condition" class="form-control" value="Бензин">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Цена за минуту (BYN)</label>
                                <input type="number" name="PricePerMinute" class="form-control" step="0.01" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Цена за час (BYN)</label>
                                <input type="number" name="PricePerHour" class="form-control" step="0.01" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Минимальное время (мин)</label>
                                <input type="number" name="MinDuration" class="form-control" value="60" required>
                            </div>
                            <div class="col-12 mb-3">
                                <label class="form-label">Адрес</label>
                                <input type="text" name="Address" class="form-control" required>
                            </div>
                            <div class="col-12 mb-3">
                                <label class="form-label">Фото загрузить</label>
                                <input type="file" name="ImageFile" class="form-control" accept="image/*" required>
                            </div>
                            <div class="col-12 mb-3">
                                <div class="form-check">
                                    <input type="checkbox" name="status" class="form-check-input" checked>
                                    <label class="form-check-label">Доступен для аренды</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save me-2"></i>Сохранить
                                </button>
                                <a href="/Admin/ManageCars" class="btn btn-secondary">
                                    <i class="fas fa-times me-2"></i>Отмена
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>


